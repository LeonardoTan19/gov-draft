{
  "name": "gov-draft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run export:server & pnpm run vite",
    "vite": "vite",
    "dev:with-export": "pnpm run export:server & pnpm run vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm lint:code && pnpm lint:styles",
    "lint:fix": "pnpm lint:code:fix && pnpm lint:styles:fix",
    "lint:code": "eslint .",
    "lint:code:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/**/*.{scss,vue}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{scss,vue}\" --fix",
    "pdf:inspect": "tsx scripts/inspect-exported-pdf.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "export:server": "tsx server/export-pdf.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "handlebars": "^4.7.8",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-vue-next": "^0.575.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.8",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/handlebars": "^4.1.0",
    "@types/jsdom": "^27.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/ui": "^4.0.18",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "express": "^4.21.2",
    "fast-check": "^4.5.3",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.1",
    "pdfjs-dist": "^5.5.207",
    "postcss-html": "^1.8.1",
    "sass-embedded": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.0-beta.13",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0-beta.13"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{scss,vue}": [
      "stylelint --fix"
    ]
  }
}
